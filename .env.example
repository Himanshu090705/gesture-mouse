# LLM Configuration for Quantum Assistant
# Copy this file to .env and fill in your API keys

# Choose your LLM provider: "auto", "groq", "openrouter", "gemini", or "ollama"
# "auto" = tries all configured keys in order: Groq → OpenRouter → Gemini → Ollama (recommended)
LLM_PROVIDER=auto

# Groq API Key — fast, generous free tier (14,400 req/day), recommended primary
# Get free key: https://console.groq.com/keys
GROQ_API_KEY=your_groq_api_key_here

# OpenRouter API Key — access to free models (DeepSeek, Mistral, Llama) with no daily hard quota
# Get free key: https://openrouter.ai/keys
OPENROUTER_API_KEY=your_openrouter_api_key_here

# Google Gemini API Key — used as fallback (free tier exhausts quickly)
# Get free key: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Note: For Ollama (local LLM), no API key needed
# Just make sure Ollama is running: ollama serve
